# =============================================
# Supabase Configuration
# =============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhxxxxxxxx

# =============================================
# Application URLs
# =============================================
APP_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
# URL server-side do backend (server actions de atendimento, lib/attendance-actions.ts).
# Tem prioridade sobre NEXT_PUBLIC_BACKEND_URL; sem ela cai no NEXT_PUBLIC_BACKEND_URL.
BACKEND_URL=http://localhost:8000
# Base do proxy de API do Next BFF p/ o backend (usado pelas rotas app/api/admin/proxy/*).
NEXT_PUBLIC_API_URL=http://localhost:8000
# Base pública do app (links/SEO/redirects).
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# E-mail de suporte exibido ao usuário sem empresa vinculada (app/no-company). Exposto no browser.
NEXT_PUBLIC_SUPPORT_EMAIL=suporte@seudominio.com
# URL da API LangChain/LangGraph exposta ao front (editor de grafo de agentes).
# NEXT_PUBLIC_LANGCHAIN_API_URL=http://localhost:8000

# =============================================
# Backend Shared Security
# Mesma chave usada pelo Next.js BFF e FastAPI para JWT interno.
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
# =============================================
INTERNAL_JWT_SECRET=xxxxxxxx

# =============================================
# Redis (workers/cache)
# Usado pelo backend Python (buffer de mensagens / scheduler) via protocolo
# RESP/TCP.
# =============================================
REDIS_URL=redis://localhost:6379/0

# =============================================
# Rate limiter distribuido (Next.js BFF) — Upstash REST
# =============================================
# O rate limiter de autenticacao (lib/rate-limit.ts) usa um store DISTRIBUIDO
# compartilhado entre instancias, para que os limites de forgot/reset/login/
# admin-login/signup sejam GLOBAIS ao cluster (e nao multiplicados por replica).
#
# Em producao (multi-replica), configure as duas variaveis abaixo com as
# credenciais REST do seu banco Upstash Redis. Sem elas, o limiter cai para um
# store EM MEMORIA (apenas DEV/local; NAO compartilhado entre instancias).
#
# Indisponibilidade do store (decidido em lib/rate-limit.ts):
#   - fail-CLOSED: login, admin-login, reset-password, signup (bloqueia).
#   - fail-OPEN : forgot-password (libera).
UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxx

# =============================================
# MinIO (Object Storage)
# =============================================
# NÃO use os defaults históricos minioadmin/minioadmin123 — estão COMPROMETIDOS
# (eram literais versionados). Gere credenciais fortes e únicas e rotacione em
# TODOS os ambientes já implantados (não só em deploys novos), auditando os logs
# de acesso do MinIO em busca de acesso indevido ao storage.
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=change-me-strong-user
MINIO_ROOT_PASSWORD=change-me-strong-password-min-8
MINIO_SECURE=false
MINIO_BUCKET=documents

# =============================================
# Stripe (Pagamentos)
# =============================================
STRIPE_SECRET_KEY=sk_test_xxxxxxxx

# =============================================
# SendGrid (Emails)
# =============================================
SENDGRID_API_KEY=SG.xxxxxxxx
SENDGRID_FROM_EMAIL=nao-responda@seudominio.com

# =============================================
# Billing
# =============================================
DOLLAR_RATE=6.00              # cotação USD->BRL usada pelo BACKEND (cobrança)
# Mesma cotação exposta ao BROWSER (painel FinOps). Precisa do prefixo NEXT_PUBLIC_
# p/ chegar no client; deve BATER com DOLLAR_RATE. Sem ela, o painel cai no fallback 6.00.
NEXT_PUBLIC_DOLLAR_RATE=6.00

# =============================================
# Session & Widget Security
# Gere ambos com: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Configure também a tabela privada do Supabase com o mesmo valor:
# INSERT INTO private.app_runtime_secrets (name, secret)
# VALUES ('widget_hmac_secret', '<same value as WIDGET_HMAC_SECRET>')
# ON CONFLICT (name) DO UPDATE SET secret = excluded.secret, updated_at = now();
# =============================================
SESSION_SECRET=xxxxxxxx
APP_SECRET=xxxxxxxx
WIDGET_HMAC_SECRET=xxxxxxxx
WIDGET_HMAC_REQUIRED=true
STRICT_URL_VALIDATION=true
USE_JWT_DB_CLIENT=false

# =============================================
# Admin API Key (mesma do backend .env)
# =============================================
ADMIN_API_KEY=xxxxxxxx

# =============================================
# OPCIONAL - Observabilidade (Sentry)
# =============================================
# SENTRY_DSN=https://xxxxxxxx@oXXXX.ingest.sentry.io/XXXX
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxx@oXXXX.ingest.sentry.io/XXXX
# Upload de source maps no build (next.config.js). So liga se os DOIS abaixo
# existirem no ambiente do build (ex.: Vercel) junto com SENTRY_AUTH_TOKEN. Sem
# eles, o build nao tenta subir source map.
# SENTRY_ORG=sua-org
# SENTRY_PROJECT=seu-projeto
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxx
