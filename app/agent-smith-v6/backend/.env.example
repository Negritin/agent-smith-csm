# =============================================
# OPCIONAL - Produção / tuning (todos têm default seguro no código)
# =============================================
# ENV=production                     # ambiente: dev | production
# TRUSTED_PROXY_HOPS=1               # nº de proxies confiáveis à frente (X-Forwarded-For)
# TRUSTED_PROXY_HOSTS=               # hosts de proxy confiáveis (comma-separated)
# WEB_CONCURRENCY=2                  # workers do uvicorn
# CHECKPOINTER_POOL_MAX=10           # pool máx. do checkpointer AsyncPostgres do LangGraph
# RUN_BUFFER_SCHEDULER=true          # liga o scheduler de buffer de mensagens neste processo
# WHATSAPP_DEDUP_TTL_SECONDS=86400   # TTL do dedup de mensagens WhatsApp
# GUARDRAIL_BASELINE_ENABLED=true    # baseline de guardrails (LlamaGuard/Presidio)
# DOCLING_MAX_WAIT=120               # timeout (s) de espera do Docling Service
# DOCLING_POLL_INTERVAL=2            # intervalo (s) de polling do Docling Service

# =============================================
# OPCIONAL - Tuning avançado (todos têm default seguro no código)
# =============================================
# USE_CELERY=false                   # true => sanitização no worker Celery; false => inline no request
# SANITIZATION_MAX_FILE_SIZE_MB=50   # tamanho máx. (MB) de arquivo na sanitização
# SANITIZATION_MAX_PAGES=200         # nº máx. de páginas por documento na sanitização
# SANITIZATION_JOB_TTL_DAYS=7        # dias de retenção do job de sanitização
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1    # override do endpoint OpenRouter
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com  # endpoint do LangSmith (region/self-host)
# BILLING_INTERVAL_MINUTES=5         # cadência (min) do beat de billing
# BILLING_BATCH_SIZE=1000            # registros de uso por lote no billing
# BILL_GROUP_MAX=500                 # máx. de itens agrupados por cobrança
# OUTBOX_DRAIN_INTERVAL_SECONDS=60   # cadência (s) do beat que drena o token_usage_outbox
# OUTBOX_DRAIN_LIMIT=100             # máx. de registros drenados do outbox por execução
# OUTBOX_STALE_MINUTES=5             # idade (min) p/ considerar item do outbox preso e re-tentar
# MCP_MAX_STDIN_PAYLOAD_BYTES=65536  # tamanho máx. (bytes) do payload stdin p/ um MCP server

