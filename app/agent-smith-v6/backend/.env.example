# GOOGLE_OAUTH_CLIENT_SECRET=xxxxxxxx
# MCP_OAUTH_REDIRECT_BASE=http://localhost:8000

# =============================================
# OPCIONAL - MCPs remotos oficiais (OAuth 2.1)
# =============================================
# Overrides de client OAuth por provider — FALLBACK usado apenas se o DCR
# (RFC 7591) falhar no provider: registre um app manualmente no portal dele
# e preencha o par abaixo. Por padrão deixe comentado (o DCR resolve sozinho
# e persiste em mcp_oauth_clients). O redirect usa o MCP_OAUTH_REDIRECT_BASE
# acima ({base}/api/mcp/oauth/callback/{provider}).
# MCP_NOTION_CLIENT_ID=xxxxxxxx
# MCP_NOTION_CLIENT_SECRET=xxxxxxxx
# MCP_KLAVIYO_CLIENT_ID=xxxxxxxx
# MCP_KLAVIYO_CLIENT_SECRET=xxxxxxxx
# MCP_SENTRY_CLIENT_ID=xxxxxxxx
# MCP_SENTRY_CLIENT_SECRET=xxxxxxxx
# MCP_SUPABASE_CLIENT_ID=xxxxxxxx
# MCP_SUPABASE_CLIENT_SECRET=xxxxxxxx
# MCP_HIGGSFIELD_CLIENT_ID=xxxxxxxx
# MCP_HIGGSFIELD_CLIENT_SECRET=xxxxxxxx

# =============================================
