# =============================================
# OBRIGATÓRIO - Supabase
# =============================================
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGxxxxxxxx  # service_role key
SUPABASE_DB_URL=postgresql://postgres.xxxxxxxx:senha@aws-0-us-west-1.pooler.supabase.com:6543/postgres
# DATABASE_URL: alias legado — o código usa SUPABASE_DB_URL acima. Mantido por compat.
DATABASE_URL=postgresql://postgres.xxxxxxxx:senha@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# =============================================
# OBRIGATÓRIO - OpenAI (embeddings e fallback)
# =============================================
OPENAI_API_KEY=sk-proj-xxxxxxxx

# =============================================
# OBRIGATÓRIO - Encryption Key
# Gere com: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# =============================================
ENCRYPTION_KEY=xxxxxxxx

# =============================================
# MinIO (Object Storage - Docker local)
# =============================================
# CREDENCIAIS: definidas SÓ aqui no .env e injetadas no container via
# `env_file: .env` do docker-compose (nenhum literal no compose versionado).
# NÃO use os defaults históricos minioadmin/minioadmin123 — estão COMPROMETIDOS
# (eram literais versionados). Gere credenciais fortes e únicas, ex.:
#   MINIO_ROOT_USER:     openssl rand -hex 16
#   MINIO_ROOT_PASSWORD: openssl rand -hex 32   (mínimo 8 chars exigido pelo MinIO)
# ROTAÇÃO: se algum ambiente já rodou com o default, rotacione em TODOS os
# ambientes (não só novos) e audite os logs de acesso do MinIO.
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=change-me-strong-user
MINIO_ROOT_PASSWORD=change-me-strong-password-min-8
MINIO_SECURE=false
MINIO_BUCKET=documents

# =============================================
# Qdrant (Vector Database - Docker local)
# Para Qdrant gerenciado/cloud: descomente QDRANT_API_KEY e use QDRANT_HTTPS=true.
# =============================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_HTTPS=false
# QDRANT_API_KEY=xxxxxxxx
EMBEDDING_DIMENSION=1536

# =============================================
# Redis (Message Buffer - Docker local)
# =============================================
REDIS_URL=redis://localhost:6379/0
BUFFER_DEBOUNCE_SECONDS=3
BUFFER_MAX_WAIT_SECONDS=30
BUFFER_TTL_SECONDS=300

# =============================================
# WhatsApp inbound webhooks (Z-API / uazapi / Evolution)
# =============================================
# A autenticação inbound usa um token de webhook POR TENANT, gerado e guardado
# por-linha em public.integrations (webhook_token*). Não há mais segredo global
# compartilhado por env var.
# Allowlist de hosts de mídia (comma-separated; vazio => check de host desabilitado).
ZAPI_MEDIA_HOST_ALLOWLIST=
UAZAPI_MEDIA_HOST_ALLOWLIST=
EVOLUTION_MEDIA_HOST_ALLOWLIST=

# =============================================
# Atendimento / SLA / Handoff — workers (S8)
# =============================================
# Segredo das ROTAS DE CONTINGÊNCIA dos workers de atendimento (SPEC §9.5):
#   POST /api/internal/attendance/{check-sla,process-inactivity-timers,process-notifications}
# O Celery beat é o gatilho CANÔNICO; estas rotas HTTP só existem para um
# scheduler externo (Supabase cron, k8s CronJob, etc.) disparar os mesmos loops
# como fallback. Validado em tempo constante (hmac.compare_digest) pelo header
# X-Scheduler-Token. Ausente => as rotas falham CLOSED (HTTP 503). Gere com:
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ATTENDANCE_SCHEDULER_SECRET=
# Cadências (em segundos) dos beats de atendimento (defaults seguem a SPEC §15/§16/§8.3):
#   SLA tick 60s (first-response crítico = 2 min), inatividade reusa o tick de 60s,
#   outbox de notificações em intervalo curto (30s) para alertas de handoff saírem rápido.
SLA_TICK_SECONDS=60
INACTIVITY_TICK_SECONDS=60
NOTIFICATIONS_TICK_SECONDS=30

# =============================================
# Server Configuration
# =============================================
HOST=0.0.0.0
PORT=8000
DEBUG=True
# APP_URL e FRONTEND_URL ficam na seção "URLs públicas (e-mails + Stripe)" abaixo.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002

# =============================================
# Session & Security
# Gere todos com: python3 -c "import secrets; print(secrets.token_hex(32))"
# =============================================
SESSION_SECRET=xxxxxxxx
APP_SECRET=xxxxxxxx
INTERNAL_JWT_SECRET=xxxxxxxx

# =============================================
# Widget & URL Security
# WIDGET_HMAC_SECRET deve bater com private.app_runtime_secrets no Supabase:
# INSERT INTO private.app_runtime_secrets (name, secret)
# VALUES ('widget_hmac_secret', '<same value as WIDGET_HMAC_SECRET>')
# ON CONFLICT (name) DO UPDATE SET secret = excluded.secret, updated_at = now();
# =============================================
WIDGET_HMAC_SECRET=xxxxxxxx
WIDGET_HMAC_REQUIRED=true
STRICT_URL_VALIDATION=true
USE_JWT_DB_CLIENT=false

# =============================================
# Billing
# =============================================
DOLLAR_RATE=6.00

