# =============================================
# OBRIGATÓRIO em produção - URLs públicas (e-mails + Stripe)
# =============================================
# URL pública do FRONTEND desta instância. Alimenta os links dos e-mails de
# billing/handoff ({FRONTEND_URL}/admin/...) e o retorno do Stripe Checkout (APP_URL).
# SEM isto, os links caem no default de dev (localhost). Sete a SUA URL real.
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000

