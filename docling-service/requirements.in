# =============================================================================
# requirements.in — human-edited dependency ranges (source of truth)
# =============================================================================
# Edit THIS file, then recompile the fully-pinned, hash-locked requirements.txt.
# Run from the REPO ROOT so the generated paths match the CI lock-drift gate:
#
#   uv pip compile docling-service/requirements.in -o docling-service/requirements.txt \
#       --generate-hashes --python-version 3.11 --no-header \
#       --no-emit-package torch --no-emit-package torchvision
#
# (or, with pip-tools: pip-compile --generate-hashes requirements.in)
#
# NOTE: PyTorch (torch / torchvision) is installed SEPARATELY in the Dockerfile
# from the CPU-only extra index (https://download.pytorch.org/whl/cpu), BEFORE
# this file. It is intentionally NOT compiled into this lock, because the CPU
# wheels live on the PyTorch index (not PyPI) and are large platform-specific
# artifacts. Keep that RUN step separate.
#
# The compiled requirements.txt is what Docker installs with --require-hashes.
# Do NOT hand-edit requirements.txt.
# =============================================================================

