# Non-interactive Vercel deployment credentials.
# Keep the real values outside Git.

VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Optional override. If empty, scripts/find-frontend.sh searches for a Next.js package.
FRONTEND_DIR=/opt/agent-smith/app/agent-smith-v6/frontend

# Public browser envs expected by most Next.js frontends. Validate after import.
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
