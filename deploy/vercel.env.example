# Non-interactive Vercel deployment credentials and production env values.
# Copy to /opt/agent-smith/.env.vercel and keep real values outside Git.

# Optional when Vercel CLI is already logged in on the VPS.
VERCEL_TOKEN=

# Optional when app/agent-smith-v6/.vercel/project.json already exists.
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Optional override. If empty, scripts/find-frontend.sh searches for Next.js.
FRONTEND_DIR=/opt/agent-smith/app/agent-smith-v6

# Frontend/BFF envs from Agent Smith V7 docs.
APP_URL=https://app.example.com
NEXT_PUBLIC_BACKEND_URL=https://api.example.com
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_BASE_URL=https://app.example.com
NEXT_PUBLIC_SUPPORT_EMAIL=suporte@example.com

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

INTERNAL_JWT_SECRET=
SESSION_SECRET=
WIDGET_HMAC_SECRET=
WIDGET_HMAC_REQUIRED=true
STRICT_URL_VALIDATION=true
USE_JWT_DB_CLIENT=false
ADMIN_API_KEY=

DOLLAR_RATE=6.00
NEXT_PUBLIC_DOLLAR_RATE=6.00

STRIPE_SECRET_KEY=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
