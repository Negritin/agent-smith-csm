REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Agent Smith backend reads QDRANT_HOST/QDRANT_PORT, not QDRANT_URL.
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=agent_smith

# Agent Smith backend reads MINIO_* directly.
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false
MINIO_BUCKET=documents

# Legacy/S3-compatible aliases kept for operational tooling.
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_BUCKET=documents
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Real project Docling microservice. Defined in docker-compose.app.template.yml.
DOCLING_SERVICE_URL=http://docling-api:8001
