# Copy this file to /opt/agent-smith/.env.external and fill real values.
# Then run: scripts/apply-external-envs.sh
# Do not commit /opt/agent-smith/.env.external.
# See deploy/EXTERNAL_SERVICES.md for provider-specific setup notes.

# Public URLs and DNS.
AGENT_SMITH_API_HOST=api.example.com
PUBLIC_SERVER_IP=5.161.73.5
FRONTEND_URL=https://app.example.com
APP_URL=https://app.example.com
ALLOWED_ORIGINS=https://app.example.com

# Supabase Cloud.
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_KEY=service_role_key_here
SUPABASE_DB_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=anon_public_key_here
# Optional helper inputs for scripts/prefill-supabase-db-url.sh when you do not
# want to paste the full SUPABASE_DB_URL manually.
SUPABASE_DB_PASSWORD=
SUPABASE_DB_REGION=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=6543
SUPABASE_DB_USER=

# Required LLM/search providers for the full app validation.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
TAVILY_API_KEY=
COHERE_API_KEY=
GROQ_API_KEY=

# Billing/email.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
DOLLAR_RATE=6.00

# Optional Vercel non-interactive auth; leave empty if the CLI login is used.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
# Optional override. If empty, derived as https://AGENT_SMITH_API_HOST.
BACKEND_URL=
# Optional override. If empty, derived as https://AGENT_SMITH_API_HOST/chat.
NEXT_PUBLIC_LANGCHAIN_API_URL=

# WhatsApp integrations are configured per tenant/provider after login
# (z-api, uazapi, evolution, meta-cloud). The current code does not read a global
# Meta token; official Meta credentials stay in the integration row.
# Optional media-host allowlists below harden inbound media downloads.
ZAPI_MEDIA_HOST_ALLOWLIST=
UAZAPI_MEDIA_HOST_ALLOWLIST=
EVOLUTION_MEDIA_HOST_ALLOWLIST=
META_GRAPH_VERSION=v23.0
WHATSAPP_DEDUP_TTL_SECONDS=86400
GOOGLE_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MCP_OAUTH_REDIRECT_BASE=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=
# Optional direct MCP access tokens for built-in local MCP servers.
GOOGLE_ACCESS_TOKEN=
GITHUB_ACCESS_TOKEN=
SLACK_ACCESS_TOKEN=
SHOPIFY_AGENT_CLIENT_ID=
SHOPIFY_AGENT_CLIENT_SECRET=
CATALOG_ID=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agent-smith
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_WORKSPACE_ID=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
NEXT_PUBLIC_SUPPORT_EMAIL=

# Optional backend tuning/advanced infrastructure.
QDRANT_API_KEY=
EMBEDDING_DIMENSION=1536
THREADPOOL_MAX_WORKERS=50
SUPABASE_HTTP2=false
DISABLE_DB_POOL_TUNE=false
MCP_MAX_STDIN_PAYLOAD_BYTES=65536
BILLING_INTERVAL_MINUTES=5
OUTBOX_DRAIN_INTERVAL_SECONDS=60
SLA_TICK_SECONDS=60
INACTIVITY_TICK_SECONDS=60
NOTIFICATIONS_TICK_SECONDS=30
BILLING_BATCH_SIZE=1000
BILL_GROUP_MAX=500
OUTBOX_DRAIN_LIMIT=100
OUTBOX_STALE_MINUTES=5

# Optional override only if generated secrets must be supplied externally.
ENCRYPTION_KEY=
SESSION_SECRET=
APP_SECRET=
INTERNAL_JWT_SECRET=
WIDGET_HMAC_SECRET=
ADMIN_API_KEY=
ATTENDANCE_SCHEDULER_SECRET=
DOCLING_SERVICE_KEY=
