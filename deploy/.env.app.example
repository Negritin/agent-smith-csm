# Agent Smith app deployment env.
# Copy to /opt/agent-smith/.env.app after importing the real upstream code.

APP_ENV=production
LOG_LEVEL=info

# Public backend route handled by Traefik/Easypanel.
AGENT_SMITH_API_HOST=api.example.com

# Build inputs. Validate after reading the real upstream Dockerfiles.
AGENT_SMITH_APP_CONTEXT=/opt/agent-smith/app/agent-smith-v6
BACKEND_DOCKERFILE=Dockerfile

# Runtime process commands. Validate after reading the real upstream docs.
BACKEND_PORT=8000
BACKEND_COMMAND=uvicorn app.main:app --host 0.0.0.0 --port 8000
WORKER_COMMAND=celery -A app.celery_app worker --loglevel=info
BEAT_COMMAND=celery -A app.celery_app beat --loglevel=info

# Public URLs.
FRONTEND_URL=https://frontend.example.com
BACKEND_CORS_ORIGINS=https://frontend.example.com
API_BASE_URL=https://api.example.com

# Application secrets.
SECRET_KEY=
JWT_SECRET=
ENCRYPTION_KEY=
WEBHOOK_SIGNING_SECRET=

# Supabase/Postgres.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/db?sslmode=require

# AI/search providers.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
COHERE_API_KEY=
TAVILY_API_KEY=

# Payments/email/messaging.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_TEMPLATE_ID=
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=
