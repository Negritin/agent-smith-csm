# Agent Smith V7 application env.
# Copy to /opt/agent-smith/.env.app and fill real values.
# Infra values such as REDIS_URL, QDRANT_HOST, MINIO_ENDPOINT and MinIO root
# credentials live in /opt/agent-smith/.env.infra.

ENV=production
DEBUG=false
BACKEND_PORT=8000
AGENT_SMITH_API_HOST=api.example.com
# Optional override for scripts/check-public-access.sh. Auto-detected otherwise.
PUBLIC_SERVER_IP=
AGENT_SMITH_BACKEND_CONTEXT=/opt/agent-smith/app/agent-smith-v6/backend
AGENT_SMITH_DOCLING_CONTEXT=/opt/agent-smith/app/agent-smith-v6/docling-service
WEB_CONCURRENCY=1
RUN_BUFFER_SCHEDULER=true
USE_CELERY=true

# Public URLs.
FRONTEND_URL=https://app.example.com
APP_URL=https://app.example.com
ALLOWED_ORIGINS=https://app.example.com

# Supabase/Postgres. SUPABASE_KEY is the service_role key.
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_DB_URL=
DATABASE_URL=

# LLMs/search/guardrails.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
TAVILY_API_KEY=
COHERE_API_KEY=
GROQ_API_KEY=
LLAMA_GUARD_FAIL_CLOSED=true

# Security. Keep matching values in Vercel for shared frontend/backend checks.
ENCRYPTION_KEY=
SESSION_SECRET=
APP_SECRET=
INTERNAL_JWT_SECRET=
WIDGET_HMAC_SECRET=
WIDGET_HMAC_REQUIRED=true
STRICT_URL_VALIDATION=true
USE_JWT_DB_CLIENT=false
ADMIN_API_KEY=
ATTENDANCE_SCHEDULER_SECRET=

# Billing/payments/email.
DOLLAR_RATE=6.00
BILLING_OUTBOX_ENABLED=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Docling custom microservice. DOCLING_SERVICE_KEY must match SERVICE_KEY.
DOCLING_SERVICE_KEY=
DOCLING_POLL_INTERVAL=5
DOCLING_MAX_WAIT=600
VISION_MODEL=gpt-4o-mini
VISION_API_URL=https://api.openai.com/v1/chat/completions
OCR_ENGINE=easyocr
MAX_FILE_SIZE_MB=100
RESULT_TTL_SECONDS=3600
DOCLING_WORKER_CONCURRENCY=2

# Optional observability/providers.
SENTRY_DSN=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agent-smith
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_WORKSPACE_ID=
GOOGLE_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MCP_OAUTH_REDIRECT_BASE=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=
GOOGLE_ACCESS_TOKEN=
GITHUB_ACCESS_TOKEN=
SLACK_ACCESS_TOKEN=
SHOPIFY_AGENT_CLIENT_ID=
SHOPIFY_AGENT_CLIENT_SECRET=
CATALOG_ID=

# Optional backend tuning/advanced infrastructure.
QDRANT_API_KEY=
EMBEDDING_DIMENSION=1536
THREADPOOL_MAX_WORKERS=50
SUPABASE_HTTP2=false
DISABLE_DB_POOL_TUNE=false
MCP_MAX_STDIN_PAYLOAD_BYTES=65536
BILLING_INTERVAL_MINUTES=5
OUTBOX_DRAIN_INTERVAL_SECONDS=60
SLA_TICK_SECONDS=60
INACTIVITY_TICK_SECONDS=60
NOTIFICATIONS_TICK_SECONDS=30
BILLING_BATCH_SIZE=1000
BILL_GROUP_MAX=500
OUTBOX_DRAIN_LIMIT=100
OUTBOX_STALE_MINUTES=5

# WhatsApp media hardening.
ZAPI_MEDIA_HOST_ALLOWLIST=
UAZAPI_MEDIA_HOST_ALLOWLIST=
EVOLUTION_MEDIA_HOST_ALLOWLIST=
WHATSAPP_DEDUP_TTL_SECONDS=86400
TRUSTED_PROXY_HOPS=1
TRUSTED_PROXY_HOSTS=
GUARDRAIL_BASELINE_ENABLED=true
